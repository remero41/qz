[
  {
    "description": "Permitir impresion directa a device path (USB directo por {file}) — sin esto QZ lanza 'not permitted'",
    "type": "property",
    "phase": "certgen",
    "os": "*",
    "data": "security.print.tofile=true"
  },
  {
    "description": "Arranque blindado QZ (tarea + watchdog)",
    "type": "Script",
    "phase": "install",
    "os": "windows",
    "data": "win-autostart.ps1"
  },
  {
    "description": "Driver WinUSB por clase impresora",
    "type": "Script",
    "phase": "install",
    "os": "windows",
    "data": "win-winusb.ps1"
  },
  {
    "description": "Limpieza arranque blindado (tareas + HKLM Run)",
    "type": "Script",
    "phase": "uninstall",
    "os": "windows",
    "data": "win-cleanup.ps1"
  },
  {
    "description": "Arranque blindado QZ (servicio systemd Restart=always)",
    "type": "Script",
    "phase": "install",
    "os": "linux",
    "data": "linux-autostart.sh"
  }
]
