--- /dev/null
+++ b/src/qz/utils/LinuxUsbInfo.java
@@ -0,0 +1,148 @@
+package qz.utils;
+
+import java.util.*;
+import java.nio.file.*;
+import org.codehaus.jettison.json.JSONObject;
+import org.codehaus.jettison.json.JSONException;
+import org.apache.logging.log4j.LogManager;
+import org.apache.logging.log4j.Logger;
+
+/**
+ * Enriquecimiento de dispositivos USB en Linux a partir de sysfs
+ * (/sys/class/usbmisc/lpN → device/{idVendor,idProduct,serial,ieee1284_id}).
+ * Produce, por dispositivo, el device path REAL (/dev/usb/lpN, resuelto por el
+ * kernel; NO se adivina el orden), el serial (desempate de impresoras iguales),
+ * el IEEE-1284 y un friendlyName. Todo campo es ADITIVO: QZ viejo no lo emite y
+ * el TPV degrada a cola.
+ *
+ * La lógica de parseo (sysfs→DeviceInfo) es pura y testeable sin Linux; la
+ * lectura real (readSysfs) va tras isLinux().
+ */
+public class LinuxUsbInfo {
+    private static final Logger log = LogManager.getLogger(LinuxUsbInfo.class);
+    private static final String USBMISC = "/sys/class/usbmisc";
+
+    public static class DeviceInfo {
+        public String vendorId, productId, serial, ieee1284, friendlyName, devicePath;
+    }
+
+    private static String norm4(String s){
+        if(s==null) return null;
+        s=s.trim().toLowerCase().replaceFirst("^0x","");
+        return s.isEmpty()?null:s;
+    }
+
+    /** sysfs: nodo("lp0") -> { idVendor, idProduct, serial, ieee1284_id, product, manufacturer }. */
+    public static Map<String,DeviceInfo> parse(Map<String,Map<String,String>> sysfs){
+        Map<String,DeviceInfo> out=new HashMap<>();
+        if(sysfs==null) return out;
+        for(Map.Entry<String,Map<String,String>> e: sysfs.entrySet()){
+            String node=e.getKey();                 // "lp0"
+            Map<String,String> v=e.getValue();
+            String vid=norm4(v.get("idVendor"));
+            String pid=norm4(v.get("idProduct"));
+            if(vid==null||pid==null) continue;      // sin identidad → se omite
+            DeviceInfo d=new DeviceInfo();
+            d.vendorId=vid; d.productId=pid;
+            d.serial = v.get("serial")!=null ? v.get("serial").trim() : null;
+            d.ieee1284 = v.get("ieee1284_id")!=null ? v.get("ieee1284_id").trim() : null;
+            d.friendlyName = firstNonEmpty(v.get("manufacturer"), v.get("product"), mdlFrom1284(d.ieee1284));
+            d.devicePath = "/dev/usb/"+node;
+            out.put(vid+":"+pid, d);                // genérico (retrocompat sin serial)
+            if(d.serial!=null && !d.serial.isEmpty()){
+                out.put(vid+":"+pid+":"+d.serial, d); // específico (desempate)
+            }
+        }
+        return out;
+    }
+
+    private static String firstNonEmpty(String... xs){
+        for(String x: xs){ if(x!=null && !x.trim().isEmpty()) return x.trim(); }
+        return null;
+    }
+    /** Extrae MDL:… del Device ID IEEE-1284 (para el friendlyName si no hay product). */
+    private static String mdlFrom1284(String ieee){
+        if(ieee==null) return null;
+        for(String part: ieee.split(";")){
+            String p=part.trim();
+            if(p.startsWith("MDL:")) return p.substring(4).trim();
+        }
+        return null;
+    }
+
+    /** Vuelca los campos ADITIVOS de un DeviceInfo sobre un JSONObject de dispositivo. */
+    public static void applyTo(JSONObject o, DeviceInfo d) throws JSONException {
+        if(d==null) return;
+        if(d.devicePath!=null)   o.put("devicePath", d.devicePath);
+        if(d.serial!=null)       o.put("serial", d.serial);
+        if(d.ieee1284!=null)     o.put("ieee1284", d.ieee1284);
+        if(d.friendlyName!=null) o.put("friendlyName", d.friendlyName);
+    }
+
+    /** Lee sysfs de verdad. Defensivo: un nodo ilegible se omite (log.warn), nunca lanza. */
+    public static Map<String,DeviceInfo> readSysfs(){
+        if(!SystemUtilities.isLinux()) return Collections.emptyMap();
+        return readSysfsFrom(Paths.get(USBMISC));
+    }
+
+    // Campos que viven en el DISPOSITIVO USB (no en la interfaz): hay que subir
+    // desde `device` (que apunta a la interfaz, p.ej. 3-3:1.0) hacia el padre 3-3.
+    private static final String[] DEVICE_FIELDS = {"idVendor","idProduct","serial","product","manufacturer"};
+    // Cuántos niveles subir como máximo buscando el device con idVendor.
+    private static final int MAX_PARENTS = 6;
+
+    /** Como readSysfs pero con base parametrizable (testeable con un /sys de fixture).
+     *  GOTCHA sysfs real: `/sys/class/usbmisc/lpN/device` es un symlink a la INTERFAZ
+     *  (3-3:1.0), donde vive `ieee1284_id`; pero `idVendor/idProduct/serial/product`
+     *  viven en el DISPOSITIVO PADRE (3-3). Por eso se resuelve el symlink y se sube
+     *  hasta encontrar `idVendor`. (Bug 2026-07-20: sin subir, vid/pid salían vacíos
+     *  y el dispositivo se descartaba → TPV imprimía por cola pese al "directo".) */
+    public static Map<String,DeviceInfo> readSysfsFrom(Path base){
+        Map<String,Map<String,String>> raw=new HashMap<>();
+        try {
+            if(!Files.isDirectory(base)) return Collections.emptyMap();
+            try(DirectoryStream<Path> ds=Files.newDirectoryStream(base,"lp*")){
+                for(Path lp: ds){
+                    try {
+                        Path iface = lp.resolve("device").toRealPath();   // la interfaz USB
+                        Path usbDev = resolveUsbDevice(iface);            // sube al dispositivo con idVendor
+                        Map<String,String> m=new HashMap<>();
+                        // vid/pid/serial/product/manufacturer desde el DISPOSITIVO
+                        if(usbDev!=null){
+                            for(String f: DEVICE_FIELDS){ readField(usbDev, f, m); }
+                        }
+                        // ieee1284_id desde la INTERFAZ (ahí lo publica usblp)
+                        readField(iface, "ieee1284_id", m);
+                        raw.put(lp.getFileName().toString(), m);
+                    } catch(Exception ex){
+                        log.warn("LinuxUsbInfo: nodo {} ilegible: {}", lp, ex.toString());
+                    }
+                }
+            }
+        } catch(Exception e){
+            log.warn("LinuxUsbInfo: no puedo leer {}: {}", base, e.toString());
+            return Collections.emptyMap();
+        }
+        return parse(raw);
+    }
+
+    /** Sube desde la interfaz hacia los padres hasta encontrar el nodo con `idVendor`
+     *  (el dispositivo USB real). Devuelve null si no aparece en MAX_PARENTS niveles. */
+    private static Path resolveUsbDevice(Path iface){
+        Path p = iface;
+        for(int i=0; i<MAX_PARENTS && p!=null; i++){
+            if(Files.isReadable(p.resolve("idVendor"))) return p;
+            p = p.getParent();
+        }
+        return null;
+    }
+
+    private static void readField(Path dir, String f, Map<String,String> m){
+        try {
+            Path fp = dir.resolve(f);
+            if(Files.isReadable(fp)){
+                m.put(f, new String(Files.readAllBytes(fp)).trim());
+            }
+        } catch(Exception ignored){}
+    }
+}
