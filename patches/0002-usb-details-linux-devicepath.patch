diff --git a/test/qz/utils/LinuxUsbInfoTest.java b/test/qz/utils/LinuxUsbInfoTest.java
new file mode 100644
index 0000000..a7bdd07
--- /dev/null
+++ b/test/qz/utils/LinuxUsbInfoTest.java
@@ -0,0 +1,66 @@
+package qz.utils;
+import org.testng.annotations.Test;
+import java.util.*;
+import org.codehaus.jettison.json.JSONObject;
+import static org.testng.Assert.*;
+
+public class LinuxUsbInfoTest {
+    private Map<String,String> node(String vid,String pid,String serial,String ieee,String prod){
+        Map<String,String> m=new HashMap<>();
+        m.put("idVendor",vid); m.put("idProduct",pid);
+        if(serial!=null) m.put("serial",serial);
+        if(ieee!=null) m.put("ieee1284_id",ieee);
+        if(prod!=null) m.put("product",prod);
+        return m;
+    }
+    // Las 3 térmicas del informe 07-18, mapeadas a lp0/lp1/lp2.
+    private Map<String,Map<String,String>> tres(){
+        Map<String,Map<String,String>> s=new LinkedHashMap<>();
+        s.put("lp0",node("0416","5011","Printer","MFG:GD32;MDL:POS58;CMD:ESC/POS;","POS58"));
+        s.put("lp1",node("04b8","0202","J4FF025969","MFG:EPSON;MDL:TM-T88IV;CMD:ESC/POS;","TM-T88IV"));
+        s.put("lp2",node("1fc9","2016","702D07693632",null,"POS-80"));
+        return s;
+    }
+    @Test public void mapea_devicePath_por_nodo(){
+        Map<String,LinuxUsbInfo.DeviceInfo> out=LinuxUsbInfo.parse(tres());
+        assertEquals(out.get("1fc9:2016").devicePath,"/dev/usb/lp2");
+        assertEquals(out.get("04b8:0202").devicePath,"/dev/usb/lp1");
+        assertEquals(out.get("0416:5011").serial,"Printer");
+    }
+    @Test public void indexa_tambien_por_serial(){
+        Map<String,LinuxUsbInfo.DeviceInfo> out=LinuxUsbInfo.parse(tres());
+        assertEquals(out.get("1fc9:2016:702D07693632").devicePath,"/dev/usb/lp2");
+    }
+    @Test public void desempata_dos_iguales_por_serial(){
+        Map<String,Map<String,String>> s=new LinkedHashMap<>();
+        s.put("lp0",node("0416","5011","AAA",null,"POS58"));
+        s.put("lp1",node("0416","5011","BBB",null,"POS58"));
+        Map<String,LinuxUsbInfo.DeviceInfo> out=LinuxUsbInfo.parse(s);
+        assertEquals(out.get("0416:5011:AAA").devicePath,"/dev/usb/lp0");
+        assertEquals(out.get("0416:5011:BBB").devicePath,"/dev/usb/lp1");
+    }
+    @Test public void sin_ieee1284_resto_ok(){
+        Map<String,LinuxUsbInfo.DeviceInfo> out=LinuxUsbInfo.parse(tres());
+        assertNull(out.get("1fc9:2016").ieee1284);
+        assertEquals(out.get("1fc9:2016").devicePath,"/dev/usb/lp2");
+    }
+    @Test public void nodo_sin_vid_pid_se_omite(){
+        Map<String,Map<String,String>> s=new HashMap<>();
+        s.put("lp0",node(null,null,"X",null,null));
+        assertTrue(LinuxUsbInfo.parse(s).isEmpty());
+    }
+    @Test public void applyTo_vuelca_campos() throws Exception {
+        JSONObject o=new JSONObject();
+        LinuxUsbInfo.applyTo(o, LinuxUsbInfo.parse(tres()).get("04b8:0202"));
+        assertEquals(o.getString("devicePath"),"/dev/usb/lp1");
+        assertEquals(o.getString("serial"),"J4FF025969");
+        assertTrue(o.getString("ieee1284").contains("ESC/POS"));
+    }
+    @Test public void applyTo_cruza_por_vidpid_lower() throws Exception {
+        Map<String,LinuxUsbInfo.DeviceInfo> info=LinuxUsbInfo.parse(tres());
+        JSONObject dev=new JSONObject(); dev.put("vendorId","0x1FC9"); dev.put("productId","0x2016");
+        String key=(dev.getString("vendorId")+":"+dev.getString("productId")).toLowerCase().replace("0x","");
+        LinuxUsbInfo.applyTo(dev, info.get(key));
+        assertEquals(dev.getString("devicePath"),"/dev/usb/lp2");
+    }
+}
